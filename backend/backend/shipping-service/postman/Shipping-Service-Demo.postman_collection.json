{
  "info": {
    "_postman_id": "9fbd9b9c-9ab4-47a4-9e7a-3a7f7f5f2e4d",
    "name": "Shipping Service Demo",
    "description": "CTSE Shipping Service demo collection. Run requests in order.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Create Shipment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": {{orderId}},\n  \"deliveryAddress\": \"Colombo Warehouse Delivery\",\n  \"shipmentStatus\": \"SHIPPED\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/shipping/create",
          "host": ["{{baseUrl}}"],
          "path": ["shipping", "create"]
        },
        "description": "Creates a shipment. Test script stores shipmentId for next requests."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "var data = pm.response.json();",
              "if (data && data.shipmentId) {",
              "  pm.collectionVariables.set('shipmentId', data.shipmentId);",
              "}",
              "if (data && data.orderId) {",
              "  pm.collectionVariables.set('orderId', data.orderId);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Get All Shipments",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/shipping",
          "host": ["{{baseUrl}}"],
          "path": ["shipping"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3) Get Shipment By OrderId",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/shipping/{{orderId}}",
          "host": ["{{baseUrl}}"],
          "path": ["shipping", "{{orderId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4) Update Shipment Status -> SHIPPED",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shipmentStatus\": \"SHIPPED\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/shipping/update-status/{{shipmentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["shipping", "update-status", "{{shipmentId}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5) Update Shipment Status -> DELIVERED",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shipmentStatus\": \"DELIVERED\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/shipping/update-status/{{shipmentId}}",
          "host": ["{{baseUrl}}"],
          "path": ["shipping", "update-status", "{{shipmentId}}"]
        },
        "description": "If Order Service integration is enabled and Order Service is down, this may return 502."
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8084"
    },
    {
      "key": "orderId",
      "value": "101"
    },
    {
      "key": "shipmentId",
      "value": "1"
    }
  ]
}
